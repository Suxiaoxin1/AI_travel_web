# ============================================
# 探途 WANDR - 后端服务配置
# ============================================

# ─── 飞猪 AI 开放平台 ───
# 获取地址: https://flyai.open.fliggy.com/#playground
FLYAI_API_KEY=你的飞猪AI_API_KEY
FLYAI_BASE_URL=https://flyai.open.fliggy.com/api/v1

# ─── 高德地图 API（路线规划）───
# 申请地址：https://console.amap.com/dev/key/app
AMAP_API_KEY=你的高德地图API_KEY
AMAP_SECRET_KEY=你的高德地图密钥(可选)

# ─── 缓存配置（秒）───
CACHE_TTL=3600
CACHE_CHECK_PERIOD=600

# ─── API 限流配置 ───
RATE_LIMIT_MAX_REQUESTS=50
RATE_LIMIT_WINDOW_MS=1000

# ─── 日志级别: error, warn, info, http, verbose, debug, silly ───
LOG_LEVEL=info

# ─── AI 日记生成（DeepSeek，国内免费）───
# 默认使用 DeepSeek V3，OpenAI 兼容格式
# 获取 Key：https://platform.deepseek.com/api_keys
AI_DIARY_BASE_URL=https://api.deepseek.com/v1
AI_DIARY_MODEL=deepseek-chat
# 备用：兼容旧版 OpenAI 配置
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini

# 服务端口
PORT=3001

# 运行模式: production | sandbox
NODE_ENV=sandbox
