# ============================================
# 探途 WANDR - 后端服务配置
# ============================================

# ─── 飞猪 AI 开放平台 ───
# 获取地址: https://flyai.open.fliggy.com/#playground
FLYAI_API_KEY=你的飞猪AI_API_KEY
FLYAI_BASE_URL=https://flyai.open.fliggy.com/api/v1

# ─── 高德地图 API（路线规划）───
# 申请地址：https://console.amap.com/dev/key/app
AMAP_API_KEY=你的高德地图API_KEY
AMAP_SECRET_KEY=你的高德地图密钥(可选)

# ─── 缓存配置（秒）───
CACHE_TTL=3600
CACHE_CHECK_PERIOD=600

# ─── API 限流配置 ───
RATE_LIMIT_MAX_REQUESTS=50
RATE_LIMIT_WINDOW_MS=1000

# ─── 日志级别: error, warn, info, http, verbose, debug, silly ───
LOG_LEVEL=info

# ─── 景区评论爬虫配置 ───
SCRAPER_CACHE_TTL=24
SCRAPER_MAX_CONCURRENT=2
SCRAPER_ENABLED=true

# ─── OpenAI API（GPT 日记生成）───
# 国内用户无法直连 api.openai.com，需要配置代理地址
# 代理服务示例：https://api.openai-proxy.com/v1  或  https://你的代理域名/v1
# 留空则使用官方地址 https://api.openai.com/v1（需科学上网）
OPENAI_BASE_URL=
# 模型名称: gpt-4o / gpt-4o-mini / chatgpt-4o-latest
OPENAI_MODEL=gpt-4o-mini

# 服务端口
PORT=3001

# 运行模式: production | sandbox
NODE_ENV=sandbox
